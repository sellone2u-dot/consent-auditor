{
  "manifest_version": 3,
  "name": "Consent Auditor — Dealer Compliance Tool",
  "version": "1.0.13",
  "description": "Dealer consent audit tool with stricter scoring for GTM overload, analytics cookies, and strong Google restricted-consent signals.",
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Consent Auditor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
